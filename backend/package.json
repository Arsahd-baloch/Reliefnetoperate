{
  "name": "disasteraid-backend",
  "version": "2.1.0",
  "description": "DisasterAid.pk V2.1 — Humanitarian platform backend",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec \"tsx src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node scripts/migrate.mjs",
    "start:migrate": "node scripts/migrate.mjs && node dist/index.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:race": "jest tests/tasks.race.test.ts --forceExit --detectOpenHandles",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "opossum": "^9.0.0",
    "pg": "^8.13.0",
    "socket.io": "^4.8.0",
    "stripe": "^17.3.0",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
